{
  "redirects": [
    {
      "source": "/boeken",
      "destination": "/beschikbaarheid",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "casa-pheli.be" }],
      "destination": "https://www.casa-pheli.be/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/galerij", "destination": "/galerij.html" },
    { "source": "/beschikbaarheid", "destination": "/beschikbaarheid.html" },
    { "source": "/beheer/kalender", "destination": "/beheer/kalender.html" },
    { "source": "/gastenboek", "destination": "/gastenboek.html" },
    { "source": "/contact", "destination": "/contact.html" }
  ],
  "headers": [
    {
      "source": "/manifest.webmanifest",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/assets/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/galerij",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/gastenboek",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/contact",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/beschikbaarheid",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/beheer/kalender",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    }
  ]
}
